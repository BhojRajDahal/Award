# ============================================
# Backend .dockerignore
# Exclude unnecessary files from Docker build context
# ============================================

# Dependencies
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment files
.env
.env*.local
.env.development
.env.production

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Testing
coverage
.nyc_output
__tests__
*.test.js
*.spec.js

# IDE
.vscode
.idea
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Git
.git
.gitignore
.gitattributes

# Documentation
README.md
*.md
docs

# Docker
Dockerfile
docker-compose.yml
.dockerignore

# Uploaded files (will be in volume)
public/photos/*
public/files/*
public/winnerPhotoes/*
!public/photos/.gitkeep
!public/files/.gitkeep
!public/winnerPhotoes/.gitkeep

# Misc
*.log
.cache

