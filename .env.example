# Copy to .env and adjust before: docker compose up -d --build

# --- Database (MySQL) ---
DB_ROOT_PASSWORD=change-me-root-password
DB_HOST=db
# Docker MySQL app user (separate from local dev DB_USER in .env)
DB_DOCKER_USER=nast
DB_DOCKER_PASSWORD=change-me-db-password
DB_NAME=nast
DB_POOL_SIZE=30

# --- App ---
NODE_ENV=production
JWT_SECRET=change-me-use-at-least-32-random-characters
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_DAYS=14
LOG_LEVEL=info
# false for local Docker on http://localhost; true when served over HTTPS
COOKIE_SECURE=false

# --- URLs (browser-facing) ---
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000
# Leave empty so the frontend uses same-origin /api via Nginx
NEXT_PUBLIC_API_BASE_URL=

# --- Ports on host ---
FRONTEND_PORT=3000
BACKEND_PORT=5000

# --- Email (optional; worker sends approval/rejection mail) ---
SMTP_USER=
SMTP_PASS=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_FROM=
